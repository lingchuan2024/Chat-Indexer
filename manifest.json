{
  "manifest_version": 3,
  "name": "AI Chat 目录导航",
  "version": "1.2.0",
  "description": "为 ChatGPT、DeepSeek、Kimi、Claude 等 AI 对话页面添加目录导航与阅读位置追踪",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://chat.deepseek.com/*",
        "https://kimi.moonshot.cn/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://yuanbao.tencent.com/*",
        "https://tongyi.aliyun.com/*",
        "https://poe.com/*",
        "https://www.perplexity.ai/*",
        "https://chat.perplexity.ai/*"
      ],
      "js": [
        "utils.js",
        "platforms.js",
        "scanner.js",
        "renderer.js",
        "layout.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
